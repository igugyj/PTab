{
  "manifest_version": 3,
  "name": "PTab",
  "version": "0.0.2",
  "description": "A beautiful new tab page with a local video background.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}